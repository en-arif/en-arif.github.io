---
import Layout from '../components/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title="Essays" description="Writing by Nur Arif">
  <div class="essays-page">
    <h1 class="page-title">Essays</h1>
    <ul class="posts-list">
      {sortedPosts.map((post) => (
        <li class="post-item">
          <span class="bullet">&#9632;</span>
          <a href={`/blog/${post.slug}`}>
            {post.data.title}
          </a>
        </li>
      ))}
    </ul>
  </div>
</Layout>

<style>
  .essays-page {
    max-width: 500px;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 5rem;
    font-family: Verdana, Geneva, sans-serif;
    font-size: 0.88rem;
  }

  .page-title {
    font-size: 1rem;
    font-weight: bold;
    font-style: italic;
    color: #555;
    margin-bottom: 0.8rem;
    font-family: Verdana, Geneva, sans-serif;
  }

  .posts-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.18rem;
  }

  .post-item {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
    line-height: 1.55;
  }

  .bullet {
    color: #888;
    font-size: 0.45rem;
    flex-shrink: 0;
    position: relative;
    top: -1px;
  }

  .post-item a {
    color: #3366cc;
    text-decoration: none;
    font-size: 0.88rem;
  }

  .post-item a:hover {
    text-decoration: underline;
  }

  .post-item a:visited {
    color: #609;
  }

  :global([data-theme="dark"]) .page-title {
    color: #999;
  }

  :global([data-theme="dark"]) .post-item a {
    color: #7aa3e5;
  }

  :global([data-theme="dark"]) .post-item a:visited {
    color: #b388dd;
  }
</style>