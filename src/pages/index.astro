---
import Layout from '../components/Layout.astro';
---

<Layout title="Cover Letter – Nur Arif" description="Cybersecurity Red Team | Penetration Testing | Writing Showcase" showSidebar={false}>
  <div class="cover-letter-page">
    <section class="hero">
      <div class="hero-content">
        <h1 class="name">WELCOME</h1>
        <p class="role">Penetration Tester & Cybersecurity Specialist</p>
        <hr class="rule" />
      </div>
    </section>

    <section class="body">
     <section class="body">
  <div class="container">
    <h2 class="section-title">Interesting to Read</h2><hr>
    <div class="project-list">
      <a href="https://github.com/nurarif/eip712-verification" target="_blank">Understanding EIP-712 Smart Account Verification</a>
      <a href="https://github.com/nurarif/eip712-verification" target="_blank">Understanding EIP-712 Smart Account Verification</a>
      <a href="https://github.com/nurarif/eip712-verification" target="_blank">Understanding EIP-712 Smart Account Verification</a>
      <a href="https://github.com/nurarif/eip712-verification" target="_blank">Understanding EIP-712 Smart Account Verification</a>
    </div>
  </div>
</section>

    </section>
  </div>

  <style>
    .cover-letter-page {
      font-family: Inter, sans-serif;
      line-height: 1.7;
      color: var(--color-text-primary);
    }

    .hero {
      text-align: center;
      background: linear-gradient(135deg, #f9f9f9, #eaeaea);
      padding: 4rem 2rem;
    }

    .name {
      font-size: 3rem;
      font-weight: 800;
      color: var(--color-accent);
      text-transform: uppercase;
    }

    .role {
      font-size: 1.25rem;
      color: var(--color-text-muted);
      margin-bottom: 1rem;
    }

    .rule {
      width: 80px;
      height: 4px;
      margin: 1rem auto;
      background: var(--color-accent);
      border: none;
    }

    .body {
      padding: 3rem 1.5rem;
    }

    .container {
      max-width: 800px;
      margin: 0 auto;
    }

    .section-title {
      font-size: 1.5rem;
      margin: rem 0 1rem;
      color: var(--color-accent);
      border-bottom: px solid var(--color-accent);
      padding-bottom: 0.25rem;
    }

    .project-list {
      list-style: none;
      padding-left: 0;
      margin-top: 1rem;
    }

    .project-list li {
      margin-bottom: 1rem;
    }

    .project-list a {
      color: var(--color-accent);
      text-decoration: none;
      font-size: 1rem;
    }

    .project-list a:hover {
      text-decoration: underline;
    }
  </style>
</Layout>



